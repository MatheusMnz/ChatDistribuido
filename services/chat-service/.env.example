# Porta do serviço (contrato: 5000)
PORT=5000

# MongoDB (mensagens/conversas)
MONGO_URL=mongodb://mongo:27017/chatdb

# Redis (Socket.IO adapter para broadcast entre instâncias)
REDIS_URL=redis://redis:6379

# Segredo JWT — DEVE ser o mesmo do auth-service
JWT_SECRET=change-me-shared-secret

# URL do auth-service (contrato)
AUTH_SERVICE_URL=http://auth-service:4000

# Identificador da instância (evidencia o balanceamento de carga nos logs)
INSTANCE_ID=chat-1
